# QA: usa .env.development | PROD: usa .env.production (según NODE_ENV)
NODE_ENV=development
PORT=3001
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
# OAuth (conectar cuenta del cliente desde el panel admin con un clic)
# Obtener en: https://developers.mercadopago.com → Tu app → Credenciales
MERCADOPAGO_CLIENT_ID=
MERCADOPAGO_CLIENT_SECRET=
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001
# URL del panel admin (para redirigir después del OAuth)
ADMIN_URL=http://localhost:5174

# Firebase: QA = hpv-desarrollo, PROD = home-pisos-vinilicos
# Descargar el JSON en Firebase Console → Configuración → Cuentas de servicio → Generar nueva clave privada
# Guardá el .json dentro de home-pisos-backend (no lo subas a git) y apuntá acá, o usá ruta absoluta.
# Alternativa: FIREBASE_SERVICE_ACCOUNT = contenido del JSON en base64 (una línea).
FIREBASE_DATABASE_URL=
GOOGLE_APPLICATION_CREDENTIALS=
# FIREBASE_SERVICE_ACCOUNT=
